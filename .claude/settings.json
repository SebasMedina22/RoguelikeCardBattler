{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git ls-tree:*)",
      "Bash(git ls-files:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git mv:*)",
      "Bash(git restore:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(xargs grep:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(where:*)",
      "Bash(which:*)",
      "Bash(npm -v)",
      "Bash(npm view:*)",
      "Bash(npx unity-mcp-cli *)",
      "Bash(openupm:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.unity3d.com)",
      "WebFetch(domain:openupm.com)",
      "WebFetch(domain:ai-game.dev)",
      "mcp__ai-game-developer__ping",
      "mcp__ai-game-developer__unity-tool-list",
      "mcp__ai-game-developer__editor-application-get-state",
      "mcp__ai-game-developer__editor-selection-get",
      "mcp__ai-game-developer__scene-list-opened",
      "mcp__ai-game-developer__scene-get-data",
      "mcp__ai-game-developer__console-get-logs",
      "mcp__ai-game-developer__gameobject-find",
      "mcp__ai-game-developer__gameobject-component-get",
      "mcp__ai-game-developer__gameobject-component-list-all",
      "mcp__ai-game-developer__assets-find",
      "mcp__ai-game-developer__assets-find-built-in",
      "mcp__ai-game-developer__assets-get-data",
      "mcp__ai-game-developer__assets-shader-list-all",
      "mcp__ai-game-developer__assets-shader-get-data",
      "mcp__ai-game-developer__object-get-data",
      "mcp__ai-game-developer__tests-run",
      "mcp__ai-game-developer__screenshot-game-view",
      "mcp__ai-game-developer__screenshot-camera",
      "mcp__ai-game-developer__screenshot-scene-view",
      "mcp__ai-game-developer__screenshot-isolated",
      "mcp__ai-game-developer__profiler-get-status",
      "mcp__ai-game-developer__profiler-get-memory-stats",
      "mcp__ai-game-developer__profiler-get-rendering-stats",
      "mcp__ai-game-developer__profiler-get-script-stats",
      "Bash(git check-ignore *)",
      "Bash(node .claude/hooks/protect-files.js)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rm -rf:*)",
      "Bash(Remove-Item:*)",
      "Bash(del:*)",
      "Bash(rd /s:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/protect-files.js"
          }
        ]
      }
    ]
  },
  "$comment": "Permisos seguros COMPARTIDOS del proyecto (este archivo se commitea). Reglas personales con rutas absolutas van en settings.local.json (local, gitignored). Precedencia: deny > ask > allow. El hook protect-files bloquea Edit/Write sobre archivos protegidos (ver .claude/hooks/protect-files.js)."
}
